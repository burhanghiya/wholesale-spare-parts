{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "numReplicas": 1,
    "sleepApplication": false,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5,
    "startCommand": "pnpm run start"
  },
  "env": {
    "NODE_ENV": "production",
    "DATABASE_URL": "${{ DATABASE_URL }}",
    "JWT_SECRET": "${{ secrets.JWT_SECRET }}",
    "OAUTH_SERVER_URL": "https://wholesale-spare-parts-production.up.railway.app",
"VITE_OAUTH_PORTAL_URL": "https://wholesale-spare-parts-production.up.railway.app",
"BUILT_IN_FORGE_API_URL": "https://wholesale-spare-parts-production.up.railway.app",
"VITE_FRONTEND_FORGE_API_URL": "https://wholesale-spare-parts-production.up.railway.app",
"VITE_ANALYTICS_ENDPOINT": "https://wholesale-spare-parts-production.up.railway.app"}
  }
}
